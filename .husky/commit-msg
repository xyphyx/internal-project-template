#!/bin/sh
# Enforce Conventional Commits format:
#   <type>(<scope>): <description>
#   type: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits, fixup commits, and squash commits
if echo "$commit_msg" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
  exit 0
fi

pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?(!)?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ✗ Invalid commit message format."
  echo ""
  echo "  Expected: <type>(<scope>): <short description>"
  echo "  Example:  feat(auth): add OAuth sign-in via Clerk"
  echo ""
  echo "  Valid types: feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
  echo ""
  exit 1
fi
