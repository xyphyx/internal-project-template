#!/bin/sh
# Pre-push hook: validate branch naming and block direct pushes to protected branches

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 1. Block direct pushes to protected branches
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "dev" ]; then
  echo ""
  echo "  ✗ Direct pushes to '$BRANCH' are not allowed."
  echo ""
  echo "  Please open a pull request instead:"
  echo "    • Feature/fix work → dev"
  echo "    • Releases         → main (via release PR from dev)"
  echo ""
  exit 1
fi

# 2. Validate branch naming convention
# Allowed: <type>/<kebab-description>  (max 50 chars after the /)
PATTERN="^(feature|fix|hotfix|chore|docs|refactor|perf|test)\/[a-z0-9]([a-z0-9\-]{0,48}[a-z0-9])?$"

if ! echo "$BRANCH" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗ Branch name '$BRANCH' does not follow the naming convention."
  echo ""
  echo "  Expected: <type>/<kebab-description>"
  echo "  Allowed types: feature | fix | hotfix | chore | docs | refactor | perf | test"
  echo "  Example:  feature/user-authentication"
  echo "            fix/XYP-42-login-error"
  echo ""
  exit 1
fi
