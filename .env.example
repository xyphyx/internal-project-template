# =============================================================================
# Environment Variables — copy to .env.local and fill in your values
# =============================================================================

# --- Convex -------------------------------------------------------------------
# Get from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# For self-hosted Convex (optional — leave unset for Convex Cloud)
# CONVEX_SELF_HOSTED_URL=http://localhost:3210
# CONVEX_SELF_HOSTED_ADMIN_KEY=your_admin_key

# --- Clerk --------------------------------------------------------------------
# Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook secret (for Convex user sync — generate in Clerk dashboard)
CLERK_WEBHOOK_SECRET=whsec_...

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
